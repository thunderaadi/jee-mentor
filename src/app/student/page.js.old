'use client'
import { useEffect } from 'react'
import { useRouter } from 'next/navigation'

export default function StudentRootPage() {
  const router = useRouter()
  useEffect(() => {
    router.replace('/student') // Wait, /student/page.js already exists. 
    // Actually, if I am in /student/page.js, this is the root.
  }, [])
  return null
}
